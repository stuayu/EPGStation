{
    "name": "epgstation",
    "version": "2.10.1-stuayu",
    "description": "DTV Software in Japan.",
    "main": "dist/index.js",
    "scripts": {
        "all-install": "npm i --no-save && cd client && npm i --no-save",
        "start": "node dist/index.js",
        "build": "npm run build-server && npm run build-client",
        "build-win": "npm run build-server && npm run build-client-win",
        "build-server": "npm run lint && npm run format && npm run compile",
        "build-client": "cd client && npm run build",
        "build-client-win": "cd client && npm run build-win",
        "lint": "eslint --fix --ext .ts src/",
        "format": "prettier --check --write src/**/*.ts",
        "compile": "tsc",
        "watch": "tsc --watch",
        "orm-gen": "typeorm migration:generate src/db/migrations/${npm_config_db}/${npm_config_name} -d ./ormconfig.js",
        "orm-run": "typeorm migration:run -d ./ormconfig.js",
        "backup": "node dist/DBTools.js -m backup -o",
        "restore": "node dist/DBTools.js -m restore -o",
        "v1migrate": "node dist/V1MigrationTool.js -i",
        "install-win-service": "winser -i -a",
        "uninstall-win-service": "winser -r -x",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/l3tnun/EPGStation-V2.git"
    },
    "author": "l3tnun",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/l3tnun/EPGStation-V2/issues"
    },
    "homepage": "https://github.com/l3tnun/EPGStation-V2#readme",
    "dependencies": {
        "arib-subtitle-timedmetadater": "4.0.10",
        "aribts": "2.1.12",
        "axios": "1.6.8",
        "cors": "2.8.5",
        "diskusage-ng": "1.0.4",
        "eventsource": "2.0.2",
        "express": "5.2.1",
        "express-openapi": "12.1.3",
        "file-type": "16.5.4",
        "inversify": "6.0.2",
        "js-yaml": "4.1.0",
        "lodash": "4.17.21",
        "log4js": "6.9.1",
        "minimist": "1.2.8",
        "mirakurun": "https://codeload.github.com/stuayu/Mirakurun/tar.gz/refs/heads/stuayu-main",
        "mkdirp": "3.0.1",
        "multer": "2.2.0",
        "openapi-types": "12.1.3",
        "reflect-metadata": "0.2.2",
        "socket.io": "4.7.5",
        "source-map-support": "0.5.21",
        "swagger-ui-dist": "5.17.2",
        "typeorm": "1.0.0",
        "url-join": "4.0.1",
        "mysql2": "3.22.6",
        "better-sqlite3": "12.11.1"
    },
    "devDependencies": {
        "@types/eventsource": "1.1.15",
        "@types/express": "5.0.6",
        "@types/file-type": "10.9.1",
        "@types/js-yaml": "4.0.9",
        "@types/lodash": "4.17.0",
        "@types/minimist": "1.2.5",
        "@types/mkdirp": "1.0.2",
        "@types/multer": "2.1.0",
        "@types/node": "24.10.1",
        "@types/serve-static": "2.2.0",
        "@types/socket.io": "3.0.1",
        "@types/source-map-support": "0.5.10",
        "@types/url-join": "4.0.3",
        "@typescript-eslint/eslint-plugin": "7.8.0",
        "@typescript-eslint/parser": "7.8.0",
        "eslint": "8.57.0",
        "eslint-config-prettier": "8.10.0",
        "prettier": "3.2.5",
        "typescript": "5.9.2"
    },
    "overrides": {
        "express-openapi": {
            "glob": "^7.0.0"
        }
    },
    "engines": {
        "node": ">=24 <25",
        "npm": ">=11 <12"
    }
}
